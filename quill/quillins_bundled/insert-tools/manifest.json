{
  "schema": "quill.extension/1",
  "id": "com.quill.bundled.insert-tools",
  "name": "Insert Tools",
  "version": "1.0.0",
  "author": "QUILL Project",
  "description": "Bundled Quillin: pure Layer 1 snippets that insert the current date, time, or both, surfaced through the Insert > Date and Time submenu. No capabilities, so it can never touch your files, network, or clipboard.",
  "license": "MIT",
  "min_quill_version": "1.0.0",
  "capabilities": [],
  "contributes": {
    "commands": [
      {
        "id": "ext.insert.date",
        "title": "Insert Date",
        "run": { "snippet": "${date}${cursor}" }
      },
      {
        "id": "ext.insert.time",
        "title": "Insert Time",
        "run": { "snippet": "${time}${cursor}" }
      },
      {
        "id": "ext.insert.datetime",
        "title": "Insert Date and Time",
        "run": { "snippet": "${date} ${time}${cursor}" }
      }
    ],
    "menus": [
      { "parent": "Date and Time", "command": "ext.insert.date" },
      { "parent": "Date and Time", "command": "ext.insert.time" },
      { "parent": "Date and Time", "command": "ext.insert.datetime" }
    ]
  }
}
