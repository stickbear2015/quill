{
  "app": "Quill",
  "github_repo": "Community-Access/quill",
  "github_labels": ["bug", "needs-triage"],
  "github_assignee": "",
  "categories": ["Bug Report", "Feature Request", "Accessibility Issue", "Other"],
  "fields": [
    {
      "name": "summary",
      "label": "Summary",
      "type": "text",
      "required": true,
      "max_length": 120,
      "placeholder": "One-line description of the issue"
    },
    {
      "name": "message",
      "label": "What happened",
      "type": "textarea",
      "required": true,
      "max_length": 5000,
      "placeholder": "Describe what went wrong"
    },
    {
      "name": "expected",
      "label": "What you expected",
      "type": "textarea",
      "required": false,
      "max_length": 2000,
      "placeholder": "What should have happened instead?"
    },
    {
      "name": "steps",
      "label": "Steps to reproduce",
      "type": "textarea",
      "required": false,
      "max_length": 2000,
      "placeholder": "1. Open Quill\n2. ..."
    },
    {
      "name": "version",
      "label": "Quill version",
      "type": "text",
      "required": false,
      "default": "__app_version__"
    },
    {
      "name": "platform",
      "label": "Operating system",
      "type": "text",
      "required": false,
      "default": "__platform__"
    },
    {
      "name": "screen_reader",
      "label": "Screen reader",
      "type": "select",
      "required": false,
      "options": [
        "Not using a screen reader",
        "JAWS",
        "NVDA",
        "Narrator",
        "VoiceOver",
        "Other"
      ]
    }
  ]
}
