<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Quill bundles its own Python framework and 160+ nested .so/.dylib
         modules (wxPython, native extensions). Under the hardened runtime the
         Python interpreter needs these relaxations to load and run that bundled
         code: JIT/unsigned executable memory for the interpreter, and library
         validation disabled so it can load the bundled extensions that are not
         part of the main signature's team. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
